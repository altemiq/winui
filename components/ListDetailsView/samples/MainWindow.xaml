<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="ListDetailsView.Samples.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Altemiq.WinUI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:ListDetailsView.Samples"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="ListDetailsView.Samples"
        mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <controls:ListDetailsView x:Name="ListDetailsView"
                                  BackButtonBehavior="Automatic"
                                  CompactModeThresholdWidth="720"
                                  ItemsSource="{Binding Emails}"
                                  NoSelectionContent="Select an item to view">
            <controls:ListDetailsView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,8">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                   Text="{Binding From}" />
                        <TextBlock Foreground="{ThemeResource Brush-Blue-01}"
                                   MaxLines="1"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Text="{Binding Subject}" />
                        <TextBlock MaxLines="1"
                                   Opacity=".6"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Text="{Binding Body}" />
                    </StackPanel>
                </DataTemplate>
            </controls:ListDetailsView.ItemTemplate>
            <controls:ListDetailsView.DetailsTemplate>
                <DataTemplate>
                    <RelativePanel Margin="24">
                        <Image x:Name="FromEllipse"
                               Width="50"
                               Height="50"
                               Source="{Binding Thumbnail}" />
                        <TextBlock Margin="12,-6,0,0"
                                   RelativePanel.RightOf="FromEllipse"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Text="{Binding From}" />
                        <TextBlock x:Name="SubjectLine"
                                   Margin="0,12,0,0"
                                   RelativePanel.Below="FromEllipse"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Text="{Binding Subject}" />
                        <TextBlock x:Name="Body"
                                   Margin="0,12,0,0"
                                   RelativePanel.Below="SubjectLine"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Text="{Binding Body}"
                                   TextWrapping="Wrap" />
                    </RelativePanel>
                </DataTemplate>
            </controls:ListDetailsView.DetailsTemplate>
            <controls:ListDetailsView.NoSelectionContentTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <SymbolIcon RenderTransformOrigin=".5,.5"
                                    Symbol="Mail">
                            <SymbolIcon.RenderTransform>
                                <CompositeTransform ScaleX="2"
                                                    ScaleY="2" />
                            </SymbolIcon.RenderTransform>
                        </SymbolIcon>
                        <TextBlock Margin="0,12"
                                   FontSize="24"
                                   Text="{Binding}" />
                    </StackPanel>
                </DataTemplate>
            </controls:ListDetailsView.NoSelectionContentTemplate>
            <controls:ListDetailsView.ListCommandBar>
                <CommandBar>
                    <!--  Button functionality to be implemented by developer  -->
                    <AppBarButton Icon="Back"
                                  Label="Back" />
                    <AppBarButton Icon="Forward"
                                  Label="Forward" />
                    <CommandBar.Content>
                        <TextBlock Margin="12,14">
                            <Run Text="{Binding Emails.Count}" />
                            <Run Text="Items" />
                        </TextBlock>
                    </CommandBar.Content>
                </CommandBar>
            </controls:ListDetailsView.ListCommandBar>
            <controls:ListDetailsView.DetailsCommandBar>
                <CommandBar>
                    <!--  Button functionality to be implemented by developer  -->
                    <AppBarButton Icon="MailReply"
                                  Label="Reply" />
                    <AppBarButton Icon="MailReplyAll"
                                  Label="Reply All" />
                    <AppBarButton Icon="MailForward"
                                  Label="Forward" />
                </CommandBar>
            </controls:ListDetailsView.DetailsCommandBar>
        </controls:ListDetailsView>
    </Grid>

</Window>
